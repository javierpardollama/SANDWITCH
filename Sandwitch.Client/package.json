{
  "name": "sandwitch.client",
  "description": "Solution for managing the current state of the spanish beaches.",
  "license": "MIT",
  "keywords": [
    "open-source",
    "csharp",
    "rest-api",
    "angular-material",
    "domain-driven-design",
    "clean-architecture",
    "electron-app",
    "nunit-tests",
    "selenium-webdriver",
    "unlicense-license",
    "sqlite3-database",
    "hexagonal-architecture",
